# AI YouTube Factory - Example Environment Configuration
# Copy this file to .env and fill in your values

# Backend
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Image Generation
POLLINATIONS_ENDPOINT=https://image.pollinations.ai/prompt/
PUTER_ENDPOINT=https://api.puter.com/v2/images
RETRY_DELAY=60
MAX_RETRIES=3
IMAGE_WIDTH=1920
IMAGE_HEIGHT=1080

# Voice Generation (Piper TTS)
PIPER_PATH=./piper/piper.exe
PIPER_MODEL=./piper/voice_model.onnx

# Subtitle Generation (Whisper)
WHISPER_PATH=./whisper/whisper.exe
WHISPER_MODEL=base

# Video Processing
FFMPEG_PATH=ffmpeg
OUTPUT_WIDTH=1920
OUTPUT_HEIGHT=1080
FPS=30
CODEC=libx264

# Worker Configuration
WORKER_COUNT=3
THREAD_COUNT=4
REQUEST_TIMEOUT=300

# Storage
STORAGE_LOCATION=./projects

# Logging
LOG_LEVEL=INFO

# YouTube API Credentials (optional - for automatic upload)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
